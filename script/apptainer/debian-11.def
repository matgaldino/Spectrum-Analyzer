Bootstrap: docker
From: debian:11

%post
  apt -qy update
  DEBIAN_FRONTEND=noninteractive apt -qy install build-essential libncursesw5 libncurses5-dev libtinfo5 libtinfo-dev locales make cmake git wget tar gzip bzip2 ca-certificates libglib2.0-0 libxext6 libxext-dev libsm6 libxrender1 python3 python3-venv ninja-build sed unzip rsync file bc findutils patch curl cvs mercurial subversion asciidoc w3m cpio perl xvfb libc6-dev-i386 net-tools default-jre java-common openssl libssl-dev pkg-config libglib2.0-dev meson libpixman-1-dev libgcrypt20-dev tclsh xterm libgtk3-nocsd0 libswt-gtk-4-java libgtk-3-dev libfdt-dev libslirp-dev
  apt -qy clean
  localedef -i en_US -c -f UTF-8 -A /usr/share/locale/locale.alias en_US.UTF-8

%environment
  export LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libgtk3-nocsd.so.0
  export LANG=en_US.UTF-8
  export LC_ALL=en_US.UTF-8
  export DISPLAY=:0
  export SESSION_MANAGER=
